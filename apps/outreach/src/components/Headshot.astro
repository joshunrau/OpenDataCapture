---
import { Image } from 'astro:assets';
import { twMerge } from 'tailwind-merge';

type Props = {
  alt: string;
  className?: string;
  src: ImageMetadata;
};

const { className, ...props } = Astro.props;
---

<Image
  class={twMerge(
    'bg-slate-200 object-cover shadow-lg rounded-full border border-slate-300 dark:border-slate-600 dark:bg-slate-700',
    className
  )}
  {...props}
/>
