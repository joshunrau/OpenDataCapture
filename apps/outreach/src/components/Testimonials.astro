---
import { getCollection } from 'astro:content';

import ArrowLeft from '@/components/ArrowLeft.astro';
import ArrowRight from '@/components/ArrowRight.astro';
import { useTranslations } from '@/i18n';

import Headshot from './Headshot.astro';

const order = ['simon-ducharme', 'massimiliano-orri', 'maxime-montembeault'];
const testimonials = await getCollection('testimonials').then((collection) => {
  collection.sort((a, b) => (order.indexOf(a.id) > order.indexOf(b.id) ? 1 : -1));
  return collection.map((item) => item.data);
});

const { resolvedLanguage } = useTranslations(Astro.url);
---

<div class="flex items-center justify-between border">
  <button
    class="text-muted-foreground rounded-full border border-slate-300 bg-slate-200 p-2 dark:border-slate-700 dark:bg-slate-800"
    id="left-testimonial-button"
  >
    <ArrowLeft />
  </button>
  <div class="relative h-[500px] w-[800px] overflow-hidden border">
    {
      testimonials.map(({ fullName, image, quote, position, suffix }, i) => (
        <div
          class="testimonial absolute flex h-full w-full flex-col items-center justify-center gap-6 border"
          style={`left: ${i * 100}%;`}
        >
          <Headshot alt={fullName} className="h-24 w-24" src={image} />
          <blockquote class="text-muted-foreground max-w-prose text-balance">{quote[resolvedLanguage]}</blockquote>
          <span class="inline-block h-1 w-10 rounded bg-sky-700" />
          <div class="flex flex-col items-center">
            <h5 class="text-foreground overflow-hidden text-ellipsis whitespace-nowrap text-lg font-semibold tracking-wide">
              {`${fullName}${suffix ? `, ${suffix}` : ''}`}
            </h5>
            <p class="text-muted-foreground overflow-hidden text-ellipsis whitespace-nowrap text-sm">
              {position[resolvedLanguage]}
            </p>
          </div>
        </div>
      ))
    }
  </div>
  <button
    class="text-muted-foreground rounded-full border border-slate-300 bg-slate-200 p-2 dark:border-slate-700 dark:bg-slate-800"
    id="right-testimonial-button"
  >
    <ArrowRight />
  </button>
</div>
<script>
  const leftButton = document.getElementById('left-testimonial-button')!;
  const rightButton = document.getElementById('right-testimonial-button')!;

  const testimonials = document.querySelectorAll<HTMLDivElement>('.testimonial');
  const maxPosition = testimonials.length * 100;

  const slide = (direction: 'LEFT' | 'RIGHT') => {
    testimonials.forEach((testimonial) => {
      let currentPosition = parseInt(testimonial.style.left);
      if (direction === 'RIGHT') {
        currentPosition = (currentPosition - 100) % maxPosition;
      } else if (direction === 'LEFT') {
        currentPosition = (currentPosition + 100) % maxPosition;
      }
      testimonial.style.left = `${currentPosition}%`;
    });
  };

  leftButton.addEventListener('click', () => slide('LEFT'));
  rightButton.addEventListener('click', () => slide('RIGHT'));
</script>
