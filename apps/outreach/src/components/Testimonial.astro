---
import { twMerge } from 'tailwind-merge';

import Headshot from './Headshot.astro';

type Props = {
  format: 'short' | 'long';
  image: ImageMetadata;
  quote: string;
  fullName: string;
  suffix?: string;
  position: string;
};

const { format, image, quote, fullName, suffix, position } = Astro.props;
---

<div
  class={twMerge(
    'h-full p-8 text-center lg:p-0 flex flex-col justify-between w-full',
    format === 'long' && 'lg:col-span-2 lg:max-w-3xl lg:mx-auto'
  )}
>
  <div>
    <div class="mb-8 flex justify-center">
      <Headshot alt={fullName} className="h-24 w-24" src={image} />
    </div>
    <p class="text-balance text-sm">{quote}</p>
  </div>
  <div>
    <span class="mb-4 mt-6 inline-block h-1 w-10 rounded bg-sky-700"></span>
    <h2
      class="overflow-hidden text-ellipsis whitespace-nowrap font-semibold tracking-wide text-slate-900 dark:text-slate-100"
    >
      {`${fullName}${suffix ? `, ${suffix}` : ''}`}
    </h2>
    <p class="overflow-hidden text-ellipsis whitespace-nowrap text-sm text-slate-700 dark:text-slate-300">
      {position}
    </p>
  </div>
</div>
