#!/usr/bin/env python3

from __future__ import annotations

import json
import os

from typing import TypedDict, Union
from argparse import ArgumentParser, MetavarTypeHelpFormatter


ConfigDict = TypedDict('ConfigDict', {'base_url': Union[str, None]}, total=False)

LoginCredentials = TypedDict('LoginCredentials', {'username': str, 'password': str})


class Config:
    _filepath = os.path.expanduser('~/.odc-cli.json')

    base_url: str | None

    def __init__(self) -> None:
        config_dict = self._load()
        self.base_url = config_dict.get('base_url')

    def write(self) -> None:
        with open(self._filepath, 'w') as file:
            json.dump(self._to_dict(), file)

    def _load(self) -> ConfigDict:
        if not os.path.exists(self._filepath):
            return {}
        with open(self._filepath, 'r') as file:
            return json.load(file)

    def _to_dict(self) -> ConfigDict:
        return {'base_url': self.base_url}


def config_command() -> None:
    pass


def login_command(username: str, password: str) -> None:
    print(username, password)


def main() -> None:
    parser = ArgumentParser(prog='open-data-capture')
    subparsers = parser.add_subparsers(help='subcommand help', required=True)

    ## AUTH
    auth_parser = subparsers.add_parser('auth')
    auth_subparsers = auth_parser.add_subparsers()

    login_parser = auth_subparsers.add_parser('login', formatter_class=MetavarTypeHelpFormatter)
    login_parser.add_argument('--username', type=str, required=True)
    login_parser.add_argument('--password', type=str, required=True)
    login_parser.set_defaults(fn=login_command)

    ## CONFIG

    config_parser = subparsers.add_parser('config')
    config_parser.set_defaults(fn=config_command)

    kwargs = vars(parser.parse_args())
    fn = kwargs.pop('fn')
    fn(**kwargs)


if __name__ == '__main__':
    main()
