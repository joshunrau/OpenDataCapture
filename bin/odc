#!/usr/bin/env python3


from __future__ import annotations

import json
import os

from argparse import ArgumentParser, MetavarTypeHelpFormatter
from typing import Any, TypedDict, Union

USER_CONFIG_FILEPATH = os.path.expanduser('~/.odc-cli.json')

UserConfig = TypedDict('UserConfig', {'base_url': Union[str, None]}, total=False)

LoginCredentials = TypedDict('LoginCredentials', {'username': str, 'password': str})


def load_user_config() -> UserConfig:
    if not os.path.exists(USER_CONFIG_FILEPATH):
        return {}
    with open(USER_CONFIG_FILEPATH, 'r') as file:
        return json.load(file)


def write_user_config(user_config: UserConfig) -> None:
    with open(USER_CONFIG_FILEPATH, 'w') as file:
        json.dump(user_config, file)


def get_config_command() -> None:
    user_config = load_user_config()
    print(user_config)


def set_config_command(**kwargs: dict[str, Any]) -> None:
    user_config = load_user_config()
    for key in kwargs:
        if kwargs[key] is not None:
            user_config[key] = kwargs[key]  # type: ignore
    write_user_config(user_config)


def login_command(username: str, password: str) -> None:
    print(username, password)


def main() -> None:
    parser = ArgumentParser(prog='open-data-capture')
    subparsers = parser.add_subparsers(help='subcommand help', required=True)

    ## AUTH
    auth_parser = subparsers.add_parser('auth')
    auth_subparsers = auth_parser.add_subparsers(required=True)

    login_parser = auth_subparsers.add_parser('login', formatter_class=MetavarTypeHelpFormatter)
    login_parser.add_argument('--username', type=str, required=True)
    login_parser.add_argument('--password', type=str, required=True)
    login_parser.set_defaults(fn=login_command)

    ## CONFIG

    config_parser = subparsers.add_parser('config')
    config_subparsers = config_parser.add_subparsers(required=True)

    get_config_parser = config_subparsers.add_parser('get')
    get_config_parser.set_defaults(fn=get_config_command)

    set_config_parser = config_subparsers.add_parser('set', formatter_class=MetavarTypeHelpFormatter)
    set_config_parser.add_argument('--base-url', type=str)
    set_config_parser.set_defaults(fn=set_config_command)

    kwargs = vars(parser.parse_args())
    fn = kwargs.pop('fn')
    fn(**kwargs)


if __name__ == '__main__':
    main()
